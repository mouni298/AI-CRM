# Copy to .env and fill in. Only GROQ_API_KEY is required for the default
# (SQLite) backend. Get a free key at https://console.groq.com/keys

# --- LLM (Groq by default; provider-agnostic via LiteLlm) ---
GROQ_API_KEY=gsk_...
# Optional model overrides (defaults are Llama 3.1 8B / Llama 3.3 70B on Groq):
# MODEL_FAST=groq/llama-3.1-8b-instant
# MODEL_SMART=groq/llama-3.3-70b-versatile
# To use a different provider, change the model prefix and set that provider's key:
# MODEL_SMART=anthropic/claude-sonnet-4-6      (then set ANTHROPIC_API_KEY)
# MODEL_SMART=gemini/gemini-2.0-flash          (then set GEMINI_API_KEY)

# --- CRM backend: "sqlite" (default, offline) or "airtable" (demo feel) ---
CRM_BACKEND=sqlite
CRM_DB_PATH=data/crm.db
# Required only when CRM_BACKEND=airtable:
# AIRTABLE_API_KEY=pat...
# AIRTABLE_BASE_ID=app...

# --- RAG ---
CHROMA_PATH=data/chroma
KB_COLLECTION=kb

# --- governance ---
CONFIDENCE_THRESHOLD=0.6

# --- A2A (M5) ---
OUTREACH_A2A_URL=http://localhost:8001
