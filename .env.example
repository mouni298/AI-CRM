# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required for the default
# (SQLite) backend.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional model overrides (defaults are Claude Haiku / Sonnet):
# MODEL_FAST=anthropic/claude-haiku-4-5-20251001
# MODEL_SMART=anthropic/claude-sonnet-4-6
# Gemini fallback example:
# MODEL_FAST=gemini/gemini-2.0-flash
# MODEL_SMART=gemini/gemini-2.0-flash

# --- CRM backend: "sqlite" (default, offline) or "airtable" (demo feel) ---
CRM_BACKEND=sqlite
CRM_DB_PATH=data/crm.db
# Required only when CRM_BACKEND=airtable:
# AIRTABLE_API_KEY=pat...
# AIRTABLE_BASE_ID=app...

# --- RAG ---
CHROMA_PATH=data/chroma
KB_COLLECTION=kb

# --- governance ---
CONFIDENCE_THRESHOLD=0.6

# --- A2A (M5) ---
OUTREACH_A2A_URL=http://localhost:8001
